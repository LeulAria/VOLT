{
  "name": "volt",
  "version": "0.1.0",
  "private": true,
  "description": "Infinite-canvas AI agent workspace",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=./apps/desktop",
    "dev:web": "turbo dev --filter=./apps/web",
    "build": "turbo build",
    "build:desktop": "turbo build --filter=./apps/desktop",
    "typecheck": "turbo typecheck",
    "lint": "oxlint apps packages --deny-warnings",
    "lint:fix": "oxlint --fix apps packages",
    "fmt": "oxfmt --ignore-path .oxfmtignore \"**/*.{ts,tsx,js,jsx,json,yaml}\"",
    "fmt:check": "oxfmt --ignore-path .oxfmtignore --check \"**/*.{ts,tsx,js,jsx,json,yaml}\"",
    "test": "turbo test",
    "clean": "turbo clean",
    "clean:hard": "turbo clean && rm -rf node_modules .turbo bun.lock",
    "package:mac": "turbo build --filter=./apps/desktop && bun --cwd apps/desktop run package:mac",
    "package:win": "turbo build --filter=./apps/desktop && bun --cwd apps/desktop run package:win",
    "package:linux": "turbo build --filter=./apps/desktop && bun --cwd apps/desktop run package:linux"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.43.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "*.json": [
      "oxfmt --write"
    ]
  },
  "packageManager": "bun@1.3.10"
}
